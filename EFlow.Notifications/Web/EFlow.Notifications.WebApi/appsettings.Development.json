{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Hangfire": "Information"
      }
    }
  },
  "BookingReminder": {
    "BookingApiBaseUrl": "http://localhost:8081/"
  },
  "Jwt": {
    "Key": "your_very_strong_secret_key_at_least_32_chars",
    "Issuer": "http://localhost:8081",
    "Audience": "http://localhost:8081",
    "ExpireMinutes": 5
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "FromEmail": "notifications@eflow.local",
    "FromName": "EFlow Debug",
    "SecureSocketOptions": "Auto"
  }
}
