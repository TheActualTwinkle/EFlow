{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:dd.MM.yyyy HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "RabbitMqSettings": {
    "Host": "localhost",
    "Port": 5673,
    "Username": "guest",
    "Password": "guest"
  },
  "ConsumersSettings": {
    "DefaultCancellationTimeout": "00:00:10"
  }
}
