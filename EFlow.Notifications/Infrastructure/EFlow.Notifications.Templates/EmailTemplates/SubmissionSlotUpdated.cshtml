@model EFlow.Notifications.Templates.Models.SubmissionSlotUpdatedEmailTemplateModel
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.Title</title>
</head>
<body style="margin:0;padding:24px;background:#f5f5f5;font-family:Inter,'Segoe UI',Arial,sans-serif;color:#111111;letter-spacing:0;">
    <div style="max-width:720px;margin:0 auto;border:1px solid #dedede;border-radius:8px;background:#ffffff;box-shadow:0 18px 44px rgba(0,0,0,.08);overflow:hidden;">
        <div style="padding:22px 24px;border-bottom:1px solid #dedede;background:#ffffff;">
            <div style="font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;color:#666666;">Обновление</div>
            <h1 style="margin:8px 0 0;font-size:26px;line-height:1.2;font-weight:780;color:#111111;">@Model.Title</h1>
            <p style="margin:12px 0 0;font-size:15px;line-height:1.6;color:#666666;">@Model.Lead</p>
        </div>

        <div style="padding:18px 24px 24px;background:#ffffff;">
            <div style="border:1px solid #dedede;border-radius:8px;background:#fafafa;padding:16px;">
                <div style="font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;color:#666666;">Актуальное состояние</div>
                <div style="margin-top:10px;font-size:18px;font-weight:780;line-height:1.3;color:#111111;">@Model.SubjectName</div>
                <div style="margin-top:6px;font-size:14px;line-height:1.45;color:#666666;">@Model.TeacherName</div>
                <div style="margin-top:6px;font-size:14px;line-height:1.45;color:#111111;">@Model.CurrentTimeRange</div>
            </div>

            @foreach (var change in Model.Changes)
            {
                <div style="margin-top:14px;border:1px solid #dedede;border-radius:8px;background:#ffffff;padding:16px;">
                    <div style="font-size:15px;font-weight:720;line-height:1.35;color:#111111;">@change.Label</div>
                    <table role="presentation" style="width:100%;margin-top:12px;border-collapse:separate;border-spacing:0 8px;">
                        <tr>
                            <td style="width:82px;padding:0;color:#666666;font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;">Было</td>
                            <td style="padding:10px 12px;border:1px solid #dedede;border-radius:8px;background:#fafafa;color:#666666;font-size:14px;line-height:1.45;">@change.OldValue</td>
                        </tr>
                        <tr>
                            <td style="padding:0;color:#666666;font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;">Стало</td>
                            <td style="padding:10px 12px;border:1px solid #dedede;border-radius:8px;background:#ffffff;color:#111111;font-size:14px;font-weight:720;line-height:1.45;">@change.NewValue</td>
                        </tr>
                    </table>
                </div>
            }
        </div>
    </div>
</body>
</html>
