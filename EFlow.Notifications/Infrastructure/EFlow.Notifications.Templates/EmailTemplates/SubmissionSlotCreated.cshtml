@model EFlow.Notifications.Templates.Models.SubmissionSlotCreatedEmailTemplateModel
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.Title</title>
</head>
<body style="margin:0;padding:24px;background:#f5f5f5;font-family:Inter,'Segoe UI',Arial,sans-serif;color:#111111;letter-spacing:0;">
    <div style="max-width:720px;margin:0 auto;border:1px solid #dedede;border-radius:8px;background:#ffffff;box-shadow:0 18px 44px rgba(0,0,0,.08);overflow:hidden;">
        <div style="padding:22px 24px;border-bottom:1px solid #dedede;background:#ffffff;">
            <div style="font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;color:#666666;">Новый слот</div>
            <h1 style="margin:8px 0 0;font-size:26px;line-height:1.2;font-weight:780;color:#111111;">@Model.Title</h1>
            <p style="margin:12px 0 0;font-size:15px;line-height:1.6;color:#666666;">@Model.Lead</p>
        </div>

        <div style="padding:18px 24px 24px;background:#ffffff;">
            <table role="presentation" style="width:100%;border-collapse:separate;border-spacing:0;">
                <tr>
                    <td style="width:50%;padding:0 7px 14px 0;vertical-align:top;">
                        <div style="min-height:92px;border:1px solid #dedede;border-radius:8px;background:#fafafa;padding:14px;">
                            <div style="font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;color:#666666;">Предмет</div>
                            <div style="margin-top:10px;font-size:18px;font-weight:780;line-height:1.3;color:#111111;">@Model.SubjectName</div>
                        </div>
                    </td>
                    <td style="width:50%;padding:0 0 14px 7px;vertical-align:top;">
                        <div style="min-height:92px;border:1px solid #dedede;border-radius:8px;background:#fafafa;padding:14px;">
                            <div style="font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;color:#666666;">Преподаватель</div>
                            <div style="margin-top:10px;font-size:18px;font-weight:780;line-height:1.3;color:#111111;">@Model.TeacherFullName</div>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td style="width:50%;padding:0 7px 0 0;vertical-align:top;">
                        <div style="min-height:92px;border:1px solid #dedede;border-radius:8px;background:#fafafa;padding:14px;">
                            <div style="font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;color:#666666;">Время</div>
                            <div style="margin-top:10px;font-size:18px;font-weight:780;line-height:1.3;color:#111111;">@Model.TimeRange</div>
                        </div>
                    </td>
                    <td style="width:50%;padding:0 0 0 7px;vertical-align:top;">
                        <div style="min-height:92px;border:1px solid #dedede;border-radius:8px;background:#fafafa;padding:14px;">
                            <div style="font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;color:#666666;">Лимит</div>
                            <div style="margin-top:10px;font-size:18px;font-weight:780;line-height:1.3;color:#111111;">@Model.Capacity</div>
                        </div>
                    </td>
                </tr>
            </table>

            <div style="margin-top:16px;border:1px solid #dedede;border-radius:8px;background:#ffffff;padding:16px;">
                <div style="font-size:13px;color:#666666;line-height:1.4;">Доступ</div>
                <div style="margin-top:5px;font-size:15px;font-weight:720;line-height:1.45;color:#111111;">@Model.Audience</div>

                <div style="margin-top:16px;font-size:13px;color:#666666;line-height:1.4;">Место</div>
                <div style="margin-top:5px;font-size:15px;line-height:1.45;color:#111111;">@Model.Location</div>

                <div style="margin-top:16px;font-size:13px;color:#666666;line-height:1.4;">Комментарий</div>
                <div style="margin-top:5px;font-size:15px;line-height:1.65;color:#111111;">@Model.Comment</div>
            </div>
        </div>
    </div>
</body>
</html>
