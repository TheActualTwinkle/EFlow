@model EFlow.Notifications.Templates.Models.SubmissionSlotCreatedEmailTemplateModel
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>@Model.Title</title>
</head>
<body style="margin:0;padding:24px;background:#eef6f1;font-family:'Segoe UI',Arial,sans-serif;color:#102a1f;">
    <div style="max-width:720px;margin:0 auto;background:#ffffff;border-radius:24px;overflow:hidden;border:1px solid #d7e7dd;box-shadow:0 22px 60px rgba(16,42,31,.08);">
        <div style="padding:34px 36px;background:linear-gradient(135deg,#0f766e 0%,#166534 100%);color:#fff;">
            <div style="display:inline-block;padding:8px 14px;border-radius:999px;background:rgba(255,255,255,.16);font-size:12px;letter-spacing:.08em;text-transform:uppercase;">Новый слот</div>
            <h1 style="margin:18px 0 10px;font-size:30px;line-height:1.15;">@Model.Title</h1>
            <p style="margin:0;font-size:16px;line-height:1.65;color:rgba(255,255,255,.86);">@Model.Lead</p>
        </div>
        <div style="padding:28px 36px;">
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;">
                <div style="padding:18px;border-radius:18px;background:#f6fffb;border:1px solid #d7f1e3;"><div style="font-size:12px;color:#4b5563;text-transform:uppercase;letter-spacing:.06em;">Предмет</div><div style="margin-top:10px;font-size:18px;font-weight:700;">@Model.SubjectName</div></div>
                <div style="padding:18px;border-radius:18px;background:#f9fafb;border:1px solid #e5e7eb;"><div style="font-size:12px;color:#4b5563;text-transform:uppercase;letter-spacing:.06em;">Преподаватель</div><div style="margin-top:10px;font-size:18px;font-weight:700;">@Model.TeacherFullName</div></div>
                <div style="padding:18px;border-radius:18px;background:#fffaf0;border:1px solid #f3e2b5;"><div style="font-size:12px;color:#4b5563;text-transform:uppercase;letter-spacing:.06em;">Время</div><div style="margin-top:10px;font-size:18px;font-weight:700;">@Model.TimeRange</div></div>
                <div style="padding:18px;border-radius:18px;background:#f8fafc;border:1px solid #e2e8f0;"><div style="font-size:12px;color:#4b5563;text-transform:uppercase;letter-spacing:.06em;">Лимит</div><div style="margin-top:10px;font-size:18px;font-weight:700;">@Model.Capacity</div></div>
            </div>
            <div style="margin-top:18px;padding:22px;border-radius:20px;background:#f8fafc;border:1px solid #e2e8f0;">
                <div style="margin-bottom:12px;font-size:14px;color:#64748b;">Доступ</div>
                <div style="font-size:16px;font-weight:600;color:#0f172a;">@Model.Audience</div>
                <div style="margin-top:18px;font-size:14px;color:#64748b;">Место</div>
                <div style="margin-top:6px;font-size:16px;color:#0f172a;">@Model.Location</div>
                <div style="margin-top:18px;font-size:14px;color:#64748b;">Комментарий</div>
                <div style="margin-top:6px;font-size:16px;color:#0f172a;line-height:1.7;">@Model.Comment</div>
            </div>
        </div>
    </div>
</body>
</html>
