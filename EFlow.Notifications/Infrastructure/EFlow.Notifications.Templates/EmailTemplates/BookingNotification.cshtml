@model EFlow.Notifications.Templates.Models.BookingEmailTemplateModel
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.Title</title>
</head>
<body style="margin:0;padding:24px;background:#f5f5f5;font-family:Inter,'Segoe UI',Arial,sans-serif;color:#111111;letter-spacing:0;">
    <div style="max-width:720px;margin:0 auto;border:1px solid #dedede;border-radius:8px;background:#ffffff;box-shadow:0 18px 44px rgba(0,0,0,.08);overflow:hidden;">
        <div style="padding:22px 24px;border-bottom:1px solid #dedede;background:#ffffff;">
            <div style="font-size:12px;font-weight:760;line-height:1;text-transform:uppercase;color:#666666;">EFlow</div>
            <h1 style="margin:8px 0 0;font-size:26px;line-height:1.2;font-weight:780;color:#111111;">@Model.Title</h1>
            <p style="margin:12px 0 0;font-size:15px;line-height:1.6;color:#666666;">@Model.Lead</p>
        </div>

        <div style="padding:18px 24px 24px;background:#ffffff;">
            <div style="display:inline-block;margin-bottom:14px;border:1px solid #dedede;border-radius:8px;background:#fafafa;padding:7px 10px;font-size:12px;font-weight:720;line-height:1;color:#111111;">@Model.AccentLabel</div>

            <table role="presentation" style="width:100%;border-collapse:separate;border-spacing:0 10px;">
                <tr>
                    <td style="width:180px;padding:0;color:#666666;font-size:13px;line-height:1.4;">Предмет</td>
                    <td style="padding:0;color:#111111;font-size:15px;font-weight:720;line-height:1.4;">@Model.SubjectName</td>
                </tr>
                <tr>
                    <td style="padding:0;color:#666666;font-size:13px;line-height:1.4;">Преподаватель</td>
                    <td style="padding:0;color:#111111;font-size:15px;font-weight:720;line-height:1.4;">@Model.TeacherName</td>
                </tr>
                <tr>
                    <td style="padding:0;color:#666666;font-size:13px;line-height:1.4;">Студент</td>
                    <td style="padding:0;color:#111111;font-size:15px;font-weight:720;line-height:1.4;">@Model.StudentFullName</td>
                </tr>
                <tr>
                    <td style="padding:0;color:#666666;font-size:13px;line-height:1.4;">Время</td>
                    <td style="padding:0;color:#111111;font-size:15px;line-height:1.4;">@Model.TimeRange</td>
                </tr>
                <tr>
                    <td style="padding:0;color:#666666;font-size:13px;line-height:1.4;">Место</td>
                    <td style="padding:0;color:#111111;font-size:15px;line-height:1.4;">@Model.Location</td>
                </tr>
            </table>

            <div style="margin-top:18px;border:1px solid #dedede;border-radius:8px;background:#fafafa;padding:14px 16px;font-size:14px;line-height:1.65;color:#666666;">
                @Model.Footer
            </div>
        </div>
    </div>
</body>
</html>
