{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "LuckyPennySoftware.MediatR.License": "Fatal",
        "Microsoft.Extensions.Http.DefaultHttpClientFactory": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:dd.MM.yyyy HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "BookingReminder": {
    "BookingApiBaseUrl": "http://booking-api:8081/",
    "PollInterval": "01:00:00"
  },
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "TopicsSettings": {
      "eflow-submission-slot-created": {
        "ReplicationFactor": 1,
        "Partitions": 1
      },
      "eflow-booking-created": {
        "ReplicationFactor": 1,
        "Partitions": 1
      },
      "eflow-booking-cancelled": {
        "ReplicationFactor": 1,
        "Partitions": 1
      },
      "eflow-submission-slot-updated": {
        "ReplicationFactor": 1,
        "Partitions": 1
      },
      "eflow-submission-slot-deleted": {
        "ReplicationFactor": 1,
        "Partitions": 1
      }
    }
  }
}
