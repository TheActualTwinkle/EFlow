{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:dd.MM.yyyy HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your_very_strong_secret_key_at_least_32_chars",
    "Issuer": "http://localhost:8081",
    "Audience": "http://localhost:8081",
    "ExpireMinutes": 1440
  },
  "ConnectionStrings": {
    "Database": "Host=localhost:5432; Database=eflow; Username=postgres; Password=123456789"
  }
}
