{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "LuckyPennySoftware.MediatR.License": "Fatal"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:dd.MM.yyyy HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your_very_strong_secret_key_at_least_32_chars",
    "Issuer": "http://localhost:8081",
    "Audience": "http://localhost:8081",
    "ExpireMinutes": 1440
  },
  "ConnectionStrings": {
    "Database": "Host=localhost:5433; Database=eflow; Username=postgres; Password=123456789",
    "HangfireDb": "Host=localhost:5433; Database=eflow; Username=postgres; Password=123456789"
  },
  "OutboxProcessorSettings": {
    "BatchSize": 20,
    "ProcessInterval": "00:00:10",
    "DeleteProcessedInterval": "01:00:00",
    "DeleteAfter": "7.00:00:00"
  },
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "Retries": 3,
    "MessageTimeoutMs": 2500,
    "TopicsSettings": {
      "eflow-submission-slot-created": {
        "ReplicationFactor": 1,
        "Partitions": 1
      },
      "eflow-booking-created": {
        "ReplicationFactor": 1,
        "Partitions": 1
      },
      "eflow-booking-cancelled": {
        "ReplicationFactor": 1,
        "Partitions": 1
      },
      "eflow-submission-slot-updated": {
        "ReplicationFactor": 1,
        "Partitions": 1
      }
    }
  }
}
